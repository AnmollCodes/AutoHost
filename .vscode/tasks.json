{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "python",
      "args": ["-m", "pytest", "tests/", "-v", "--tb=short"],
      "problemMatcher": ["$pytest"],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Run Tests with Coverage",
      "type": "shell",
      "command": "python",
      "args": ["-m", "pytest", "tests/", "-v", "--cov=agent", "--cov-report=html", "--cov-report=term-missing"],
      "problemMatcher": ["$pytest"],
      "group": "test"
    },
    {
      "label": "Format Code",
      "type": "shell",
      "command": "ruff",
      "args": ["format", "agent", "tests"],
      "group": "build"
    },
    {
      "label": "Lint Code",
      "type": "shell",
      "command": "ruff",
      "args": ["check", "agent", "tests", "--fix"],
      "group": "build"
    },
    {
      "label": "Type Check",
      "type": "shell",
      "command": "mypy",
      "args": ["agent", "--ignore-missing-imports"],
      "problemMatcher": ["$mypy"],
      "group": "build"
    },
    {
      "label": "Security Check",
      "type": "shell",
      "command": "bandit",
      "args": ["-r", "agent", "-ll"],
      "group": "build"
    },
    {
      "label": "Start Development Server",
      "type": "shell",
      "command": "python",
      "args": ["-m", "uvicorn", "agent.orchestrator.server:app", "--reload"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "isBackground": true
    },
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "pip",
      "args": ["install", "-e", ".[dev]"],
      "group": "build"
    }
  ]
}
