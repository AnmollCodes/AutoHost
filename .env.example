# AutoHost Configuration
# Copy this file to .env and customize as needed
# All variables are prefixed with AUTOHOST_

# =============================================================================
# LLM Settings
# =============================================================================

# Ollama API endpoint
AUTOHOST_OLLAMA_URL=http://localhost:11434/api/generate

# Model to use (run 'ollama list' to see available models)
AUTOHOST_OLLAMA_MODEL=kimi-k2.5:cloud

# Request timeout in seconds
AUTOHOST_OLLAMA_TIMEOUT=120

# Max tokens for LLM response
AUTOHOST_MAX_TOKENS=2048

# Context window size (increase for longer prompts/conversations)
# Common values: 4096, 8192, 16384, 32768 (depends on model support)
AUTOHOST_NUM_CTX=8192

# JSON parsing retry attempts
AUTOHOST_MAX_JSON_RETRIES=2

# =============================================================================
# Sandbox Settings (for isolated code execution)
# =============================================================================

# Execution timeout in seconds
AUTOHOST_SANDBOX_TIMEOUT=30

# Docker resource limits
AUTOHOST_SANDBOX_MEMORY_LIMIT=256m
AUTOHOST_SANDBOX_CPU_LIMIT=1
AUTOHOST_SANDBOX_PIDS_LIMIT=50
AUTOHOST_DOCKER_IMAGE=python:3.12-slim

# =============================================================================
# Server Settings (for web UI)
# =============================================================================

AUTOHOST_SERVER_HOST=127.0.0.1
AUTOHOST_SERVER_PORT=8000
AUTOHOST_SESSION_TIMEOUT=3600
AUTOHOST_MAX_HISTORY_MESSAGES=20

# =============================================================================
# Execution Settings
# =============================================================================

# Max code fix retries on error
AUTOHOST_MAX_CODE_RETRIES=2

# Enable parallel step execution
AUTOHOST_PARALLEL_EXECUTION=true

# Max auto-retry attempts with different approach on failure
AUTOHOST_MAX_RECOVERY_ATTEMPTS=3

# Run Python code in Docker sandbox (requires Docker installed)
# If false (default), runs directly on your system
AUTOHOST_USE_DOCKER=false

# Show detailed step-by-step execution (thoughts and actions)
# If false, only shows spinner with success/error dots
AUTOHOST_SHOW_STEPS=true

# =============================================================================
# File Permission Settings
# =============================================================================

# Comma-separated list of allowed paths (glob patterns supported)
# Empty means allow all paths (with confirmation for sensitive ones)
# Examples: ~/projects,~/Documents,/tmp
AUTOHOST_ALLOWED_PATHS=

# Comma-separated list of denied paths (always blocked)
# These paths are NEVER accessible, even with confirmation
AUTOHOST_DENIED_PATHS=~/.ssh,~/.gnupg,~/.aws,~/.config/gcloud,/etc/passwd,/etc/shadow

# Require confirmation for paths outside allowed_paths
AUTOHOST_REQUIRE_PATH_CONFIRMATION=true

# Require approval before executing plans
AUTOHOST_REQUIRE_APPROVAL=true
